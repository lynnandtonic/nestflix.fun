extends _includes/skeleton

block vars 
    - var title = "Talk Shows";
    - var description = "Talk shows within other films and shows.";
    - var bodyClass = "category";

include _includes/mixin-feature
include _includes/mixin-cards
include _includes/mixin-entry-img

block content
    section.hero
        +entry-img('Montague')
        +entry-img('Today in Fashion')
        +entry-img('Wayne’s World')
        +entry-img('Dishing Davenport')
        +entry-img('Live! with Murray Franklin')
        .info
            h1 Talk Shows on Nestflix

    span#content

    - var tags = ['talk shows', 'political talk shows', 'public-access talk shows', 'entertainment commentary', 'late night talk shows', 'variety shows'];

    +cards(0,2)
    +feature('Night Owls with Jack Delroy')(class='feature-1 top')
    +feature('Wayne’s World')(class='feature-2 top')
    +feature('Dishing Davenport')(class='feature-3 top')
    +cards(2,4)
    +feature('Obah')(class='feature-1')
    +feature('Montague')(class='feature-2 top')
    +feature('The Squawk')(class='feature-3 top')
    +cards(4,6)
